root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,yaml,yml,toml}]
indent_size = 2

[*.{md,mdx}]
trim_trailing_whitespace = false

[*.css,scss,less]
indent_size = 2

[*.{html,htm,svg,vue,svelte}]
indent_size = 2

[*.{rs,rlib}]
indent_size = 4
hard_tabs = false

[*.{cpp,cc,cxx,h,hpp,hxx}]
indent_size = 4
hard_tabs = false

[*.py]
indent_size = 4

[*.sh]
indent_size = 2

[Makefile]
indent_style = tab

[CMakeLists.txt]
indent_size = 2

[Dockerfile]
indent_size = 2

[*.proto]
indent_size = 2

[.editorconfig]
indent_size = 2
