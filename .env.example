# World-Office Docker Compose Environment
# =========================================
# Copy this file to .env and customize values for your setup.
#   cp .env.example .env
#
# These values are used by docker-compose.yml and docker-compose.override.yml.
# DO NOT commit .env to version control.

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_DB=world_office
POSTGRES_USER=worldoffice
POSTGRES_PASSWORD=worldoffice_dev

# Redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# pgAdmin (used by docker-compose.override.yml only)
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@world-office.dev
PGADMIN_PASSWORD=admin
