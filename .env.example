# World-Office Docker Compose Environment
# =========================================
# Copy this file to .env and customize values for your setup.
#   cp .env.example .env
#
# These values are used by docker-compose.yml and docker-compose.services.yml.
# DO NOT commit .env to version control.

# ── Security ────────────────────────────────────────────────────────────

# JWT signing secret — MUST be changed in production.
# Must be at least 32 characters, shared across all services.
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars

# ── Logging ─────────────────────────────────────────────────────────────

# Rust log level for all services (trace|debug|info|warn|error)
RUST_LOG=info

# ── Infrastructure ──────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_PORT=5432
POSTGRES_DB=world_office
POSTGRES_USER=worldoffice
POSTGRES_PASSWORD=worldoffice_dev

# Redis
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# pgAdmin (used by docker-compose.override.yml only)
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@world-office.dev
PGADMIN_PASSWORD=admin

# ── Service Ports (host-side) ───────────────────────────────────────────

IDENTITY_PORT=8001
STORAGE_PORT=8002
CONVERSION_PORT=8003
COAUTHORING_PORT=8004
SESSION_PORT=8005
GATEWAY_PORT=8080
DOCSERVER_PORT=80

# ── Document Server ─────────────────────────────────────────────────────

# Override the JWT secret for the document server (falls back to JWT_SECRET)
DOCSERVER_JWT_SECRET=

# WOPI upstream URL (e.g., OpenCloud/OCIS)
WOPI_HOST_URL=http://ocis:9200
