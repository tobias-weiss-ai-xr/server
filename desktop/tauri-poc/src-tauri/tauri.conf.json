{
  "identifier": "com.worldoffice.desktop",
  "productName": "World Office",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3006"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "World Office",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "rpm", "dmg", "app", "appimage"],
    "icon": [
      "icons/icon.png"
    ],
    "resources": [],
    "fileAssociations": [
      {
        "ext": ["docx", "doc"],
        "name": "word-document",
        "description": "Word Document",
        "mimeType": "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
      },
      {
        "ext": ["xlsx", "xls"],
        "name": "excel-spreadsheet",
        "description": "Excel Spreadsheet",
        "mimeType": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
      },
      {
        "ext": ["pptx", "ppt"],
        "name": "powerpoint-presentation",
        "description": "PowerPoint Presentation",
        "mimeType": "application/vnd.openxmlformats-officedocument.presentationml.presentation"
      },
      {
        "ext": ["pdf"],
        "name": "pdf-document",
        "description": "PDF Document",
        "mimeType": "application/pdf"
      },
      {
        "ext": ["odt"],
        "name": "odt-document",
        "description": "OpenDocument Text",
        "mimeType": "application/vnd.oasis.opendocument.text"
      },
      {
        "ext": ["ods"],
        "name": "ods-spreadsheet",
        "description": "OpenDocument Spreadsheet",
        "mimeType": "application/vnd.oasis.opendocument.spreadsheet"
      },
      {
        "ext": ["odp"],
        "name": "odp-presentation",
        "description": "OpenDocument Presentation",
        "mimeType": "application/vnd.oasis.opendocument.presentation"
      },
      {
        "ext": ["rtf"],
        "name": "rtf-document",
        "description": "Rich Text Format",
        "mimeType": "application/rtf"
      },
      {
        "ext": ["txt"],
        "name": "text-document",
        "description": "Plain Text",
        "mimeType": "text/plain"
      },
      {
        "ext": ["html", "htm"],
        "name": "html-document",
        "description": "HTML Document",
        "mimeType": "text/html"
      },
      {
        "ext": ["epub"],
        "name": "epub-document",
        "description": "EPUB eBook",
        "mimeType": "application/epub+zip"
      },
      {
        "ext": ["fb2"],
        "name": "fb2-document",
        "description": "FictionBook",
        "mimeType": "application/x-fictionbook+xml"
      }
    ],
    "copyright": "Copyright © 2026 World Office",
    "category": "Utility",
    "shortDescription": "World Office — Independent Document Suite",
    "longDescription": "World Office is a modern, open-source office suite supporting DOCX, XLSX, PPTX, PDF, ODF, and more.",
    "linux": {
      "deb": {
        "depends": [],
        "priority": "optional",
        "section": "utils"
      },
      "rpm": {
        "depends": [],
        "release": "1"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "minimumSystemVersion": "10.15",
      "providerShortName": "WO",
      "signingIdentity": null
    },
    "windows": {
      "nsis": {
        "languages": ["English", "German", "French", "Spanish"],
        "displayLanguageSelector": true,
        "installMode": "currentUser",
        "template": null,
        "installerIcon": "icons/icon.ico",
        "headerImage": null,
        "sidebarImage": null
      },
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": null,
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
