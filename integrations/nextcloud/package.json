        "type": "git",
        "url": "git+https://github.com/word-office/worldoffice-nextcloud.git"
    },
    "bugs": {
        "url": "https://github.com/word-office/worldoffice-nextcloud/issues",
        "email": "support@worldoffice.org"
    },
    "keywords": [
        "worldoffice",
        "nextcloud"
    ],
    "license": "AGPL-3.0",
    "private": true,
    "scripts": {
        "build": "vite build --mode production",
        "dev": "vite build --mode development"
    },
