<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error — World-Office Cloud</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .error-page {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: var(--spacing-xl);
      text-align: center;
    }
    .error-page h1 {
      font-size: 4rem;
      color: var(--error);
      margin-bottom: var(--spacing-md);
    }
    .error-page p {
      font-size: 1.25rem;
      max-width: 500px;
    }
  </style>
</head>
<body>
  <div class="error-page">
    <div>
      <h1>Error</h1>
      <p><%= message %></p>
      <a href="/" class="btn btn-primary mt-lg">Back to Dashboard</a>
    </div>
  </div>
</body>
</html>
