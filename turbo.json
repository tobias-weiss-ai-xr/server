{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "dependsOn": ["^dev"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "cargo:check": {
      "outputs": ["target/**"]
    },
    "cargo:build": {
      "dependsOn": ["cargo:check"],
      "outputs": ["target/**"]
    },
    "cargo:test": {
      "dependsOn": ["cargo:check"],
      "outputs": ["target/**"]
    },
    "cargo:lint": {
      "outputs": []
    },
    "cargo:fmt": {
      "outputs": []
    }
  }
}
